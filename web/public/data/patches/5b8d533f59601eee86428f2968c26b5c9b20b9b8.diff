+fn serialize_compact_raw_json<S>(
+    event: &&RawValue,
+    serializer: S,
+) -> std::result::Result<S::Ok, S::Error>
+where
+    S: Serializer,
+{
+    let value = serde_json::from_str::<Value>(event.get()).map_err(serde::ser::Error::custom)?;
+    value.serialize(serializer)
+}
